generator client {
  provider      = "prisma-client-js"
  // "native" = ton PC Windows (dev local)
  // debian-openssl-3.0.x = VPS Debian/Ubuntu récent (le plus courant)
  // debian-openssl-1.1.x = VPS Debian/Ubuntu plus ancien
  // Si le VPS tourne sur Alpine ou RHEL/CentOS, dis-le pour ajuster cette liste.
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Reservation {
  id         String   @id @default(cuid())
  name       String
  phone      String   @default("")
  email      String
  service    String
  slot       String
  date       String
  notes      String   @default("")
  status     String   @default("pending")
  source     String   @default("online")
  stylistId  String?
  stylist    Stylist? @relation(fields: [stylistId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Leave {
  id        String   @id @default(cuid())
  startDate String
  endDate   String
  note      String   @default("")
  createdAt DateTime @default(now())
}

// services = JSON array of service IDs this stylist can perform, e.g. ["coupe","coloration"]
model Stylist {
  id           String        @id @default(cuid())
  name         String
  services     String        @default("[]")
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}
